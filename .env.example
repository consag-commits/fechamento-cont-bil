# Copie para .env (local) ou configure como variáveis de ambiente no Railway.

# Segurança
SECRET_KEY=troque-por-uma-chave-aleatoria-longa
DEBUG=False
ALLOWED_HOSTS=seu-app.up.railway.app
CSRF_TRUSTED_ORIGINS=https://seu-app.up.railway.app

# Banco de dados — deixe DATABASE_URL vazia/ausente para usar sqlite local.
# Em produção (Railway), referencie a variável DATABASE_URL do serviço Postgres.
DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco

# API da Omie (usada só pelo comando sincronizar_omie, para popular o
# autocomplete de empresas). Nunca hardcode essas chaves no código.
OMIE_APP_KEY=
OMIE_APP_SECRET=
