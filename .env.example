# Copie para .env (local) ou configure como variáveis de ambiente no Railway.

# Segurança
SECRET_KEY=troque-por-uma-chave-aleatoria-longa
DEBUG=False
ALLOWED_HOSTS=seu-app.up.railway.app
CSRF_TRUSTED_ORIGINS=https://seu-app.up.railway.app

# Banco de dados — deixe DB_ENGINE vazio/ausente para usar sqlite local.
# Defina DB_ENGINE=mssql em produção (Railway) para usar SQL Server.
DB_ENGINE=mssql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=1433
